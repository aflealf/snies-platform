# ============================================================================
# SNIES Data Platform - Variables de Entorno
# ============================================================================
# Copia este archivo a .env y ajusta los valores según tu entorno:
#   cp .env.example .env
# ============================================================================

# -------------------- PostgreSQL: Data Warehouse --------------------
# Base de datos principal donde viven Bronze, Silver y Gold.
DWH_POSTGRES_USER=snies
DWH_POSTGRES_PASSWORD=snies_pwd_change_me
DWH_POSTGRES_DB=snies_dwh
DWH_POSTGRES_PORT=5432

# -------------------- PostgreSQL: Airflow Metadata --------------------
# Base de datos separada que Airflow usa para su propia metadata.
# No toques estos datos manualmente.
AIRFLOW_POSTGRES_USER=airflow
AIRFLOW_POSTGRES_PASSWORD=airflow_pwd_change_me
AIRFLOW_POSTGRES_DB=airflow

# -------------------- Airflow --------------------
# Credenciales para entrar a la UI en http://localhost:8080
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin
AIRFLOW_ADMIN_EMAIL=admin@example.com

# Fernet key para encriptar conexiones en la metadata DB.
# Genera una nueva con:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=46BKJoQYlPPOexq0OhDZnIlNepKFf87WFwLbfzqDDho=

# Secret key para firmar sesiones del webserver.
# Genera una con: python -c "import secrets; print(secrets.token_hex(32))"
AIRFLOW_SECRET_KEY=change_me_to_a_long_random_string_in_production

# Puerto expuesto al host para la UI de Airflow
AIRFLOW_WEBSERVER_PORT=8080

# Zona horaria
AIRFLOW_TIMEZONE=America/Bogota

# -------------------- Metabase (BI demo) --------------------
METABASE_PORT=3000
