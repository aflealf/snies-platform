# =============================================================================
# SNIES Data Platform - .gitignore
# =============================================================================

# --- Secretos ---
.env
.env.local
*.pem
*.key

# --- Airflow ---
airflow/logs/
airflow/plugins/__pycache__/
airflow/dags/__pycache__/
airflow/dags/*/__pycache__/

# --- dbt ---
dbt/target/
dbt/dbt_packages/
dbt/logs/
dbt/.user.yml

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# --- Sistemas operativos ---
.DS_Store
Thumbs.db
*.swp
*.swo

# --- IDEs ---
.idea/
.vscode/
*.iml

# --- Datos descargados (si alguien descarga local para pruebas) ---
data/
tmp/
downloads/

# --- Docker ---
docker-volumes/

# --- Mermaid CLI ---
puppeteer-config.json
